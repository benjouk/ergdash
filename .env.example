C2_CLIENT_ID=
C2_CLIENT_SECRET=
C2_REDIRECT_URI=http://localhost:3100/auth/callback
C2_API_BASE=https://log.concept2.com
PORT=3000
DATA_DIR=/data
SYNC_INTERVAL_MINUTES=15
# Required in production. Generate with: openssl rand -base64 32
SESSION_SECRET=
# Optional: force the session cookie's Secure flag. Defaults to auto
# (Secure when C2_REDIRECT_URI is https://, off for http://localhost).
COOKIE_SECURE=
# Canonical application origin when TLS terminates at a reverse proxy.
# Example: https://ergdash.example.com. Leave empty for direct LAN HTTP;
# ErgDash does not force HTTPS or upgrade LAN assets.
APP_ORIGIN=
# Optional: allow credentialed cross-origin API access from this explicit origin.
# Leave empty (disabled) for normal setups — the frontend is served same-origin.
# In production this must be an https:// origin, never '*'.
CORS_ORIGIN=
# Nightly automatic database backups into DATA_DIR/backups (default on).
# Set BACKUP_ENABLED=0 to disable; BACKUP_KEEP controls how many are retained.
BACKUP_ENABLED=
BACKUP_KEEP=
# Optional: explicit local-development-only API auth bypass. Do not set in production.
ERGDASH_DEV_AUTH_BYPASS=
# Optional: explicitly load mock workouts/goals/plans on non-production starts.
# Never enable this for a database that may contain real user data.
ERGDASH_SEED_DEMO=
