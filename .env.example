C2_CLIENT_ID=
C2_CLIENT_SECRET=
C2_REDIRECT_URI=http://localhost:3100/auth/callback
C2_API_BASE=https://log.concept2.com
PORT=3000
DATA_DIR=/data
SYNC_INTERVAL_MINUTES=15
# Required in production. Generate with: openssl rand -base64 32
SESSION_SECRET=
# Optional: force the session cookie's Secure flag. Defaults to auto
# (Secure when C2_REDIRECT_URI is https://, off for http://localhost).
COOKIE_SECURE=
# Optional: allow cross-origin API access from this origin. Leave empty
# (disabled) for normal setups — the frontend is served same-origin.
CORS_ORIGIN=
